{
  "name": "@subpay/solana",
  "version": "0.1.0",
  "description": "TypeScript SDK for USDC recurring payments on Solana",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "@solana/wallet-adapter-react": ">=0.15.0",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@solana/web3.js": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "typescript": "^5.4.5"
  }
}
